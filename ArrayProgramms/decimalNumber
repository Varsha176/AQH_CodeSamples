Q_1: Find and sum all decimal numbers
input = {1,2.1,3,4.2} op = 6.3

  -------------------------------
  package com.practice;

public class findAndAddDecimalNumbers {
	public static void main(String args[])
	{
		
		double a [] = {1,2.1,3,4.2};
		double sum =0;
		for(int i=0;i<a.length;i++)
		{
			if(!(a[i]%1  == 0))
			{
				sum = (double) (sum +a[i]);
			}
		}
		System.out.print("sum of decimal no is"+sum);
	}
}
