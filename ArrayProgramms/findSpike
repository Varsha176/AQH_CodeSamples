class Main {
    public static void main(String[] args) {
        int input [] = {3,4,14,7};
        System.out.println(detectFirstAnomaly(input));
        
    }
    
    public static int detectFirstAnomaly(int[] input) 
    {
     int max =  input[0];
     System.out.println("max element is"+max);
     for(int i=1;i<input.length;i++)
     {
         if(input[i]>=3*max)
         {
             max = input[i];
             return i;
             
         }
         else
         {
             continue;
         }
     }
     return -1;
    }
}
